# .env (Backend)
# Remplacez les valeurs par celles de votre environnement de production lors du déploiement.

# Clé secrète Django (Générez-en une nouvelle pour la production)
SECRET_KEY=django-insecure-&k=5f5bkmk8#gpr(ejwmjhlmqa3)481wranb74@7+e)0qu5_!o

# Mode Debug (Doit être False en production)
DEBUG=False

# Hôtes autorisés (ex: mon-api.onrender.com,localhost,127.0.0.1)
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Origines CORS autorisées (ex: https://mon-front.vercel.app,http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# URL de la base de données (PostgreSQL, MySQL, etc.)
# Exemple PostgreSQL: postgres://user:password@hostname:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Module de paramètres Django (development ou production)
DJANGO_SETTINGS_MODULE=backend.settings.production

# Sentry DSN pour le suivi des erreurs (Backend)
SENTRY_DSN=

