# .env (Frontend)
# Variables d'environnement pour l'application React / Vite.
# Toutes les variables doivent commencer par VITE_ pour être accessibles dans le code React.

# URL de l'API Backend (A modifier lors du déploiement vers l'URL de production de l'API)
VITE_API_URL=http://localhost:8000/api/tasks/

# Sentry DSN pour le suivi des erreurs (Frontend React)
VITE_SENTRY_DSN=
